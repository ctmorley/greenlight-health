generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ────────────────────────────────────────────

enum OrganizationType {
  imaging_center
  surgical_center
  hospital
  multi_specialty
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType @default(imaging_center)
  npi       String?
  taxId     String?
  address   String?
  phone     String?
  fax       String?
  email     String?
  settings  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  users          User[]
  patients       Patient[]
  requests       PriorAuthRequest[]
  ehrConnections EhrConnection[]

  @@map("organizations")
}

// ─── User ────────────────────────────────────────────────────

enum UserRole {
  admin
  pa_coordinator
  physician
  viewer
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole  @default(viewer)
  title          String?
  npiNumber      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  createdRequests  PriorAuthRequest[] @relation("CreatedBy")
  assignedRequests PriorAuthRequest[] @relation("AssignedTo")
  orderingRequests PriorAuthRequest[] @relation("OrderingPhysician")
  uploadedDocs     AuthDocument[]
  statusChanges    AuthStatusChange[]
  filedAppeals     Appeal[]

  @@map("users")
}

// ─── Patient ─────────────────────────────────────────────────

enum Gender {
  male
  female
  other
  unknown
}

model Patient {
  id             String  @id @default(cuid())
  organizationId String
  mrn            String
  firstName      String
  lastName       String
  dob            DateTime
  gender         Gender  @default(unknown)
  phone          String?
  email          String?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  insurances   PatientInsurance[]
  requests     PriorAuthRequest[]

  @@unique([organizationId, mrn])
  @@map("patients")
}

// ─── Patient Insurance ───────────────────────────────────────

enum PlanType {
  hmo
  ppo
  epo
  pos
  medicaid
  medicare
  tricare
  other
}

model PatientInsurance {
  id              String    @id @default(cuid())
  patientId       String
  payerId         String
  planName        String
  planType        PlanType  @default(other)
  memberId        String
  groupNumber     String?
  isPrimary       Boolean   @default(true)
  effectiveDate   DateTime
  terminationDate DateTime?

  patient  Patient  @relation(fields: [patientId], references: [id])
  payer    Payer    @relation(fields: [payerId], references: [id])
  requests PriorAuthRequest[]

  @@map("patient_insurances")
}

// ─── Payer ───────────────────────────────────────────────────

enum PayerType {
  commercial
  medicare
  medicaid
  tricare
}

enum RbmVendor {
  evicore
  carelon
  nia
  direct
}

model Payer {
  id                   String    @id @default(cuid())
  name                 String
  payerId              String    @unique
  type                 PayerType @default(commercial)
  phone                String?
  fax                  String?
  portalUrl            String?
  electronicSubmission Boolean   @default(false)
  avgResponseDays      Int       @default(5)
  rbmVendor            RbmVendor?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())

  rules              PayerRule[]
  insurances         PatientInsurance[]
  requests           PriorAuthRequest[]
  clinicalPolicies   PayerClinicalPolicy[]
  docRequirements    DocumentationRequirement[]
  denialPatterns     DenialPattern[]

  @@map("payers")
}

// ─── Payer Rule ──────────────────────────────────────────────

enum ServiceCategory {
  imaging
  surgical
  medical
}

model PayerRule {
  id               String          @id @default(cuid())
  payerId          String
  serviceCategory  ServiceCategory
  cptCode          String?
  requiresPA       Boolean         @default(true)
  clinicalCriteria Json?
  validFrom        DateTime        @default(now())
  validTo          DateTime?
  createdAt        DateTime        @default(now())

  payer Payer @relation(fields: [payerId], references: [id])

  @@map("payer_rules")
}

// ─── ACR Appropriateness Criteria ────────────────────────────

enum AppropriatenessRating {
  usually_not_appropriate    // ACR 1-3
  may_be_appropriate         // ACR 4-6
  usually_appropriate        // ACR 7-9
}

enum EvidenceStrength {
  strong
  moderate
  limited
  insufficient
  consensus
}

model ClinicalGuideline {
  id                    String                @id @default(cuid())
  source                String                @default("ACR")         // ACR, EviCore, Carelon, CMS, etc.
  sourceVersion         String?                                       // e.g., "2024 Update"
  topicId               String?                                       // ACR topic ID
  condition             String                                        // e.g., "Acute Low Back Pain"
  variant               String                                        // Clinical scenario description
  procedure             String                                        // e.g., "MRI lumbar spine without IV contrast"
  cptCodes              String[]                                      // Mapped CPT codes for this procedure
  icd10Codes            String[]                                      // Common ICD-10 codes for this condition
  rating                Int                                           // 1-9 scale
  ratingCategory        AppropriatenessRating                         // Derived from rating
  evidenceStrength      EvidenceStrength      @default(limited)
  radiationLevel        Int?                                          // 0-5 relative radiation level
  radiationDose         String?                                       // e.g., "1-10 mSv"
  panelSpecialty        String?                                       // e.g., "Musculoskeletal"
  narrative             String?                                       // Guideline narrative text
  references            Json?                                         // PubMed references
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  payerPolicies         PayerClinicalPolicy[]

  @@index([condition])
  @@index([cptCodes])
  @@index([rating])
  @@index([source, topicId])
  @@map("clinical_guidelines")
}

// ─── Payer Clinical Policy ──────────────────────────────────

model PayerClinicalPolicy {
  id                    String              @id @default(cuid())
  payerId               String
  guidelineId           String?
  serviceCategory       ServiceCategory
  cptCode               String?                                       // Specific CPT, or null for category-wide
  policyName            String                                        // e.g., "Lumbar MRI Policy"
  policySource          String              @default("payer_manual")  // payer_manual, evicore, carelon, nia, cms
  requiresPA            Boolean             @default(true)
  minAcrRating          Int?                                          // Minimum ACR rating for auto-approval
  requiredDocuments     String[]                                      // e.g., ["clinical_notes", "prior_imaging"]
  conservativeTxDays    Int?                                          // Minimum conservative treatment days
  requiresReferral      Boolean             @default(false)
  requiresPeerReview    Boolean             @default(false)
  additionalCriteria    Json?                                         // Structured criteria beyond the standard fields
  commonDenialReasons   String[]                                      // Known denial reasons for this policy
  approvalRate          Float?                                        // Historical approval rate (0-1)
  avgTurnaroundDays     Int?                                          // Historical avg response time
  effectiveDate         DateTime            @default(now())
  expirationDate        DateTime?
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  payer                 Payer               @relation(fields: [payerId], references: [id])
  guideline             ClinicalGuideline?  @relation(fields: [guidelineId], references: [id])

  @@index([payerId, cptCode])
  @@index([payerId, serviceCategory])
  @@map("payer_clinical_policies")
}

// ─── Documentation Requirement ──────────────────────────────

model DocumentationRequirement {
  id                    String              @id @default(cuid())
  payerId               String?                                       // null = universal requirement
  rbmVendor             RbmVendor?                                    // EviCore, Carelon, NIA
  serviceCategory       ServiceCategory
  serviceType           ServiceType?
  cptCode               String?
  documentType          String                                        // e.g., "clinical_notes", "prior_imaging_report"
  description           String                                        // Human-readable description
  isRequired            Boolean             @default(true)
  conditionalLogic      Json?                                         // When this doc is required (e.g., only if patient > 65)
  createdAt             DateTime            @default(now())

  payer                 Payer?              @relation(fields: [payerId], references: [id])

  @@index([payerId, serviceCategory])
  @@index([cptCode])
  @@map("documentation_requirements")
}

// ─── Denial Pattern ─────────────────────────────────────────

model DenialPattern {
  id                    String              @id @default(cuid())
  payerId               String?
  rbmVendor             RbmVendor?
  serviceCategory       ServiceCategory?
  cptCode               String?
  icd10Code             String?
  reasonCategory        DenialReasonCategory
  reasonDescription     String
  frequency             Int                 @default(0)             // How often this denial occurs
  preventionTip         String?                                     // How to avoid this denial
  requiredEvidence      String[]                                    // What to include to prevent this denial
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  payer                 Payer?              @relation(fields: [payerId], references: [id])

  @@index([payerId, cptCode])
  @@index([reasonCategory])
  @@map("denial_patterns")
}

// ─── Prior Auth Request ──────────────────────────────────────

enum AuthStatus {
  draft
  submitted
  pending_review
  approved
  partially_approved
  denied
  appealed
  expired
  cancelled
}

enum Urgency {
  routine
  urgent
  emergent
}

enum ServiceType {
  mri
  ct
  pet_ct
  ultrasound
  xray
  fluoroscopy
  mammography
  dexa
  nuclear
  surgical_procedure
  medical_procedure
}

model PriorAuthRequest {
  id              String          @id @default(cuid())
  organizationId  String
  patientId       String
  createdById     String
  assignedToId    String?
  referenceNumber String          @unique
  status          AuthStatus      @default(draft)
  urgency         Urgency         @default(routine)
  serviceCategory ServiceCategory?
  serviceType     ServiceType?
  cptCodes        String[]
  icd10Codes      String[]
  procedureDescription String?

  payerId              String?
  insuranceId          String?
  rbmVendor            RbmVendor?
  rbmReferenceNumber   String?

  orderingPhysicianId  String?
  renderingPhysicianNpi String?
  facilityName         String?
  scheduledDate        DateTime?
  dueDate              DateTime?

  clinicalNotes  String?
  aiAuditResult  Json?
  draftMetadata  Json?

  submittedAt    DateTime?
  decidedAt      DateTime?
  expiresAt      DateTime?

  approvedUnits    Int?
  approvedCptCodes String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id])
  patient           Patient           @relation(fields: [patientId], references: [id])
  createdBy         User              @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo        User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  orderingPhysician User?             @relation("OrderingPhysician", fields: [orderingPhysicianId], references: [id])
  payer             Payer?            @relation(fields: [payerId], references: [id])
  insurance         PatientInsurance? @relation(fields: [insuranceId], references: [id])

  documents     AuthDocument[]
  statusChanges AuthStatusChange[]
  denials       Denial[]
  appeals       Appeal[]

  @@map("prior_auth_requests")
}

// ─── Auth Document ───────────────────────────────────────────

enum DocumentCategory {
  clinical_notes
  imaging_order
  lab_results
  referral
  medical_records
  letter_of_necessity
  other
}

model AuthDocument {
  id           String           @id @default(cuid())
  priorAuthId  String
  uploadedById String
  fileName     String
  fileType     String
  filePath     String
  fileSize     Int
  category     DocumentCategory @default(other)
  createdAt    DateTime         @default(now())

  priorAuth  PriorAuthRequest @relation(fields: [priorAuthId], references: [id])
  uploadedBy User             @relation(fields: [uploadedById], references: [id])

  @@map("auth_documents")
}

// ─── Auth Status Change (Audit Log) ─────────────────────────

model AuthStatusChange {
  id          String     @id @default(cuid())
  priorAuthId String
  changedById String
  fromStatus  AuthStatus
  toStatus    AuthStatus
  note        String?
  metadata    Json?
  createdAt   DateTime   @default(now())

  priorAuth PriorAuthRequest @relation(fields: [priorAuthId], references: [id])
  changedBy User             @relation(fields: [changedById], references: [id])

  @@map("auth_status_changes")
}

// ─── Denial ──────────────────────────────────────────────────

enum DenialReasonCategory {
  medical_necessity
  incomplete_documentation
  out_of_network
  service_not_covered
  missing_precert
  coding_error
  other
}

model Denial {
  id                String              @id @default(cuid())
  priorAuthId       String
  denialDate        DateTime
  reasonCode        String?
  reasonCategory    DenialReasonCategory
  reasonDescription String?
  payerNotes        String?
  createdAt         DateTime            @default(now())

  priorAuth PriorAuthRequest @relation(fields: [priorAuthId], references: [id])
  appeals   Appeal[]

  @@map("denials")
}

// ─── Appeal ──────────────────────────────────────────────────

enum AppealLevel {
  first
  second
  external_review
}

enum AppealStatus {
  draft
  filed
  in_review
  won
  lost
  withdrawn
}

model Appeal {
  id            String       @id @default(cuid())
  priorAuthId   String
  denialId      String
  appealLevel   AppealLevel
  filedDate     DateTime
  filedById     String
  appealReason  String
  status        AppealStatus @default(draft)
  decisionDate  DateTime?
  decisionNotes String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  priorAuth PriorAuthRequest @relation(fields: [priorAuthId], references: [id])
  denial    Denial           @relation(fields: [denialId], references: [id])
  filedBy   User             @relation(fields: [filedById], references: [id])

  @@map("appeals")
}

// ─── EHR Connection (SMART on FHIR) ─────────────────────────

enum EhrVendor {
  epic
  oracle_health
  meditech
  athenahealth
  veradigm
  eclinicalworks
  other
}

model EhrConnection {
  id             String      @id @default(cuid())
  organizationId String
  label          String // Display name, e.g., "Main Campus Epic"
  vendor         EhrVendor
  fhirBaseUrl    String // FHIR R4 server base URL (the `iss`)
  clientId       String // SMART app client_id registered with this EHR
  scopes         String? // Granted scopes (stored after first successful launch)
  isActive       Boolean     @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, fhirBaseUrl])
  @@map("ehr_connections")
}
