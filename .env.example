# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/greenlight"

# NextAuth
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMART on FHIR (EHR Integration)
# Client ID registered with EHR vendor (e.g., Epic App Orchard)
NEXT_PUBLIC_SMART_CLIENT_ID="greenlight-health"

# Anthropic AI (Claude)
ANTHROPIC_API_KEY=""

# PHI Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In production: use Azure Key Vault reference
PHI_ENCRYPTION_KEY=""

# Email (Resend)
# Sign up at resend.com, verify your domain, and grab the API key
RESEND_API_KEY=""
NOTIFICATION_FROM_EMAIL="notifications@greenlighthealth.com"

# Document Storage (Azure Blob)
# When set, documents are stored in Azure Blob Storage.
# When empty, falls back to local filesystem (dev only — files lost on redeploy).
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="documents"

# Stripe Billing
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
